# ---------------------------------------------------------------------------
# Caddyfile for the email-gate application
#
# Place at:  /etc/caddy/Caddyfile  (or include via import)
# Replace:   your-domain.com with your actual domain
#
# Caddy handles TLS automatically — no Certbot needed.
#
# Reload:    sudo systemctl reload caddy
# Logs:      sudo journalctl -u caddy -f
# ---------------------------------------------------------------------------

# Redirect www → bare domain (remove if you prefer www)
#www.spam-america.com {
    #redir https://www.your-domain.com{uri} permanent
#}

www.spam-america.com {

    # -----------------------------------------------------------------------
    # Security headers
    # -----------------------------------------------------------------------
    header {
        X-Frame-Options          "SAMEORIGIN"
        X-Content-Type-Options   "nosniff"
        Referrer-Policy          "strict-origin-when-cross-origin"
        -Server
    }

    # -----------------------------------------------------------------------
    # REST API — proxy to Node.js API server
    # -----------------------------------------------------------------------
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # -----------------------------------------------------------------------
    # Protected static website (served with path-fix injection by Node.js)
    # -----------------------------------------------------------------------
    handle /site/* {
        reverse_proxy localhost:3000
    }

    # -----------------------------------------------------------------------
    # Protected site's absolute-path assets (content-hashed — cache forever)
    # -----------------------------------------------------------------------
    handle /assets/* {
        reverse_proxy localhost:3000 {
            header_up Host {host}
        }
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # -----------------------------------------------------------------------
    # PDF / document downloads from the protected site
    # -----------------------------------------------------------------------
    handle /documents/* {
        reverse_proxy localhost:3000
    }

    # -----------------------------------------------------------------------
    # Email gate SPA — serve static files, fall back to index.html
    # -----------------------------------------------------------------------
    handle {
        root * /opt/email-gate/email-gate/public

        # Prevent caching of the gate entry point so the session check always runs
        @nocache path / /index.html
        header @nocache Cache-Control "no-store, no-cache, must-revalidate"

        try_files {path} /index.html
        file_server
    }
}
